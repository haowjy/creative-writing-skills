{
    "name": "creative-writing-skills",
    "owner": {
      "name": "Jimmy Yao",
      "email": "dev.jimm.py@gmail.com"
    },
    "metadata": {
      "description": "Creative writing agents and skills for Claude Code",
      "version": "0.1.0"
    },
    "plugins": [
      {
        "name": "creative-writing-skills",
        "description": "A set of composable agents and skills for creative writing projects. The story-orchestrator agent is the primary entry point — it coordinates brainstorming, drafting, critique, and knowledge maintenance across all specialized agents.",
        "source": "./",
        "strict": false,
        "agents": [
          "./cw/agents/brainstormer.md",
          "./cw/agents/character-sim.md",
          "./cw/agents/chronicler.md",
          "./cw/agents/continuity-checker.md",
          "./cw/agents/critic.md",
          "./cw/agents/draft-orchestrator.md",
          "./cw/agents/explorer.md",
          "./cw/agents/graph-maintainer.md",
          "./cw/agents/knowledge-orchestrator.md",
          "./cw/agents/outliner.md",
          "./cw/agents/reader-sim.md",
          "./cw/agents/researcher.md",
          "./cw/agents/session-miner.md",
          "./cw/agents/story-orchestrator.md",
          "./cw/agents/style-creator.md",
          "./cw/agents/wiki-editor.md",
          "./cw/agents/writer.md"
        ],
        "skills": [
          "./cw/skills/brainstorming",
          "./cw/skills/knowledge-graph",
          "./cw/skills/prose-analysis",
          "./cw/skills/prose-critique",
          "./cw/skills/prose-writing",
          "./cw/skills/story-architecture",
          "./cw/skills/story-context",
          "./cw/skills/story-decisions",
          "./cw/skills/wiki-docs",
          "./cw/skills/writing-artifacts",
          "./cw/skills/writing-principles",
          "./cw/skills/writing-staffing"
        ]
      },
      {
        "name": "creative-writing-router",
        "description": "Natural-language skill router for Claude.ai web UI users who cannot install agents. Not needed for Claude Code users — use the story-orchestrator agent instead.",
        "source": "./",
        "strict": false,
        "skills": [
          "./cw/cw-router"
        ]
      }
    ]
  }
