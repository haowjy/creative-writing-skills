{
    "name": "creative-writing-skills",
    "owner": {
      "name": "Jimmy Yao",
      "email": "dev.jimm.py@gmail.com"
    },
    "metadata": {
      "description": "Creative writing agents and skills for Claude Code",
      "version": "0.1.0"
    },
    "plugins": [
      {
        "name": "creative-writing-skills",
        "description": "A set of composable agents and skills for creative writing projects. The story-orchestrator agent is the primary entry point. It coordinates brainstorming, drafting, critique, and knowledge maintenance across all specialized agents.",
        "source": "./",
        "strict": false,
        "agents": [
          "./agents/brainstormer.md",
          "./agents/character-sim.md",
          "./agents/chronicler.md",
          "./agents/continuity-checker.md",
          "./agents/critic.md",
          "./agents/draft-orchestrator.md",
          "./agents/explorer.md",
          "./agents/graph-maintainer.md",
          "./agents/knowledge-orchestrator.md",
          "./agents/outliner.md",
          "./agents/reader-sim.md",
          "./agents/researcher.md",
          "./agents/session-miner.md",
          "./agents/story-orchestrator.md",
          "./agents/style-creator.md",
          "./agents/wiki-editor.md",
          "./agents/writer.md"
        ],
        "skills": [
          "./skills/brainstorming",
          "./skills/prose-critique",
          "./skills/prose-writing",
          "./skills/story-architecture",
          "./skills/story-context",
          "./skills/story-decisions",
          "./skills/wiki-docs",
          "./skills/writing-artifacts",
          "./skills/writing-principles",
          "./skills/writing-staffing"
        ]
      },
      {
        "name": "creative-writing-router",
        "description": "Natural-language skill router for Claude.ai web UI users who cannot install agents. Not needed for Claude Code users. Use the story-orchestrator agent instead.",
        "source": "./",
        "strict": false,
        "skills": [
          "./cw/cw-router"
        ]
      }
    ]
  }
